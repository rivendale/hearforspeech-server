HFS_ALLOWED_ORIGINS=https://hearforspeech.com,http://localhost:5173,http://127.0.0.1:5173
HFS_MAX_UPLOAD_MB=50
HFS_MAX_BATCH_FILES=40
# Optional. If set, clients must send X-HFS-API-Key.
HFS_API_KEY=
# Optional MFA alignment readiness. Install MFA separately, then point these at local model files/names.
HFS_MFA_ACOUSTIC_MODEL=
HFS_MFA_DICTIONARY=
